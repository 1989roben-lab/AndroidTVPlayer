<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#040506"
                android:startColor="#2A2E35" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#2DFFFFFF" />
        </shape>
    </item>

    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#0A0C10"
                android:startColor="#4C515A" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#12151B"
                android:startColor="#3B4049" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="52dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#42FFFFFF" />
            <corners
                android:topLeftRadius="16dp"
                android:topRightRadius="16dp"
                android:bottomLeftRadius="34dp"
                android:bottomRightRadius="34dp" />
        </shape>
    </item>

    <item
        android:left="22dp"
        android:top="22dp"
        android:right="22dp"
        android:bottom="22dp"
        android:drawable="@drawable/ic_app_mark" />
</layer-list>
